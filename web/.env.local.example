# Supabase — project credentials (client + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — CLI auth (so migrations can be applied headlessly)
# Generate a Personal Access Token: https://supabase.com/dashboard/account/tokens
# Project ref is the subdomain of your Supabase URL (e.g. "abcdef123" in https://abcdef123.supabase.co)
SUPABASE_ACCESS_TOKEN=your-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# Translation engine
ENGINE_URL=https://audiosolutions-production.up.railway.app

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (comma-separated emails that bypass free-tier limits)
ADMIN_EMAILS=your-email@example.com
